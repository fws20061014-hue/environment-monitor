{
  "name": "helmet-worker-admin",
  "version": "1.0.0",
  "private": true,
  "description": "Windows desktop admin app for smart helmet worker monitoring.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "cn.fws.helmet.worker.admin",
    "productName": "安全帽工人状态管理员",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^37.8.0",
    "electron-builder": "^26.8.1"
  }
}
